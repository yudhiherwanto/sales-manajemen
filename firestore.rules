rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function isSignedIn() { 
      return request.auth != null; 
    }
    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function isManager() {
      return getUserData().role == 'manager';
    }
    function isSales() {
      return getUserData().role == 'sales';
    }
    function isOwner(salespersonId) {
      return request.auth.uid == salespersonId;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // User profiles
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && isManager();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && request.auth.uid == userId 
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']);
    }

    // Leads
    match /leads/{leadId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isSales() 
                    && request.resource.data.salespersonId == request.auth.uid;
      allow update: if isSignedIn() && (
        isManager() || 
        (isSales() && resource.data.salespersonId == request.auth.uid)
      );
      allow delete: if isSignedIn() && isManager();
    }

    // Visits
    match /visits/{visitId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isSales() 
                    && request.resource.data.salespersonId == request.auth.uid;
      allow update, delete: if isSignedIn() && isManager();
    }
  }
}
